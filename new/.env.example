# API Keys — copy this file to .env and fill in your keys.
# NEVER commit .env to git (it is in .gitignore).

# HuggingFace (required for gated models like MedGemma)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (required for GPT-4o evaluation)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (required for Claude evaluation)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google (required for Gemini evaluation)
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
